modules = ["python-3.12"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["geckodriver", "iana-etc", "libev"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Bot"

[[workflows.workflow]]
name = "Run Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 app.py"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8765
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", ".venv/bin/gunicorn --worker-class geventwebsocket.gunicorn.workers.GeventWebSocketWorker -w 1 app:app -b 0.0.0.0:5000"]
build = ["bash", "-c", "python3 -m venv .venv && .venv/bin/pip install --upgrade pip && .venv/bin/pip install flask flask-socketio 'gunicorn[gevent]' gevent gevent-websocket requests beautifulsoup4 selenium"]
